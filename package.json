{
  "name": "@wsapichat/n8n-nodes-wsapi",
  "version": "2.0.1",
  "description": "A comprehensive n8n community node for WSAPI - the powerful WhatsApp API Gateway. Easily integrate WhatsApp messaging, contact management, group operations, and more into your n8n workflows.",
  "keywords": [
    "n8n-community-node-package",
    "whatsapp",
    "whatsapp-business-api",
    "messaging",
    "wsapi",
    "chat",
    "automation",
    "webhook",
    "communication",
    "api"
  ],
  "license": "MIT",
  "homepage": "https://wsapi.chat",
  "author": {
    "name": "WSAPI",
    "email": "support@wsapi.chat"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wsapi-chat/n8n-nodes-wsapi.git"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "format": "prettier nodes credentials --write",
    "format:check": "prettier nodes credentials --check",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "deploy:local": "npm run build && rm -rf .local-deploy && mkdir -p .local-deploy && cp package.json .local-deploy/ && cp -r dist .local-deploy/",
    "release": "n8n-node release",
    "prepublishOnly": "npm run build",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/WSApiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/WSApi/WsApi.node.js",
      "dist/nodes/WSApi/WsApiTrigger.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "^9.39.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}